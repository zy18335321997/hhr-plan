{
  "$description": "execution_lock.json validation schema. The lock is the only design source of truth; execution_contract.json is derived.",
  "schema_version": "2.0",
  "required_top_keys": [
    "meta",
    "target",
    "naming",
    "sheets",
    "associations",
    "workflows",
    "gates"
